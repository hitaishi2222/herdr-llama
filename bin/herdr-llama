#!/usr/bin/env bash
# Wrapper to open herdr overlay pane and run herdr-llama inside it.
# Captures the current tab_id before opening the overlay so the Python
# script can refocus that tab after model selection.

set -eu
herdr="${HERDR_BIN_PATH:-herdr}"

# Capture the tab focused before the overlay opens.
original_tab_id="$(herdr pane current 2>/dev/null | jq -r '.result.pane.tab_id')"
export HERDR_TAB_ID="$original_tab_id"

# Read dashboard-placement from config (default: overlay)
config_dir="$HOME/.config/herdr/plugins/config/herdr-llama"
placement=$(grep -oP 'dashboard-placement\s*=\s*\K.*' "$config_dir/herdr-llama.ini" 2>/dev/null || echo "popup")
placement=$(echo "$placement" | tr -d '[:space:]')

if [ "$placement" = "popup" ]; then
    exec "$herdr" plugin pane open --plugin herdr-llama --entrypoint dashboard --placement popup --width "60%" --height "40%" --focus
else
    exec "$herdr" plugin pane open --plugin herdr-llama --entrypoint dashboard --placement overlay --focus
fi
